# Go build artifacts
/server
/server.exe
/bin/
# CI-produced and local build artifacts (binaries + installer)
/dnshenet-server.exe
/dnshenet-server-linux-amd64
/dnshenet-server-windows-amd64.exe
/dnshenet-server-windows-amd64-installer.exe
/dnshenet-server-installer.exe

# MCP tool directories and logs
.playwright-mcp/
alarm-mcp.log

# SQLite database files (contain production data)
*.db
*.db-wal
*.db-shm

# Environment files (contain credentials)
.env
.env.*
# WHY exception for .env.example: it is a credential-free template committed to the
# repo so the Inno Setup installer (installer/dnshenet-server.iss) can bundle it and
# copy it to C:\dnshenet-server.env on first install. Without this exception, the
# .env.* glob above would exclude it from being tracked.
!.env.example

# TLS certificates and private keys (self-signed dev certs — never commit keys)
/server.crt
/server.key

# Debug / development artifacts
debug-*.html
/screenshots/

# Editor / OS
.DS_Store
Thumbs.db
*.swp
*.swo

# Test output
/coverage.out
/coverage.html

# Build artifacts
dnshenet-server.exe~
screenshots.exe

CLAUDE.md
/.gitlab
.gitlab-ci.yml
/.gitlabi/ci
/.planning

