# DNS HE.NET Automation — server configuration
# Copy this file to C:\dnshenet-server.env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── Required ─────────────────────────────────────────────────────────────────

# HMAC-SHA256 signing secret for JWT tokens. Minimum 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_SECRET

# ── Server ───────────────────────────────────────────────────────────────────

DB_PATH=C:\Program Files\dnshenet-server\dnshenet-server.db
PORT=9001
LOG_LEVEL=info

# ── TLS (HTTPS) ───────────────────────────────────────────────────────────────
# Paths to PEM certificate and private key. Leave empty to use plain HTTP.
# The installer generates a self-signed cert at the paths below.
# To use your own cert, replace these paths or leave blank for plain HTTP.
SSL_CERT=C:\Program Files\dnshenet-server\server.crt
SSL_KEY=C:\Program Files\dnshenet-server\server.key

# ── Admin UI ─────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin

# ADMIN_PASSWORD is optional.
# Leave empty → the server reads the password from the database (default on first start: admin123).
# Set a value → the server bcrypt-hashes it, stores the hash in the database, and uses it
#   as the new admin password. The env value can be cleared after the first start that commits
#   it to the DB — the hash persists across restarts.
#
# Use this to set or change the admin password without editing the database directly:
#   1. Set ADMIN_PASSWORD=your-new-password
#   2. Restart the server (it hashes and saves the new password)
#   3. Clear ADMIN_PASSWORD= (empty) to stop exposing the plaintext in the env file
#   4. Restart again — the server reads the stored hash from the DB
ADMIN_PASSWORD=

# ── Optional ─────────────────────────────────────────────────────────────────
# METRICS_PORT=9090
# PLAYWRIGHT_HEADLESS=true
# OPERATION_TIMEOUT_SEC=30
