# DNS HE.NET Automation — server configuration
# Copy this file to C:\dnshenet-server.env and fill in your values.
# Lines starting with # are comments and are ignored.

# ── Required ─────────────────────────────────────────────────────────────────

# HMAC-SHA256 signing secret for JWT tokens. Minimum 32 characters.
# Generate with: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_RANDOM_32_CHAR_SECRET

# ── Server ───────────────────────────────────────────────────────────────────

DB_PATH=C:\Program Files\dnshenet-server\dnshenet-server.db
PORT=9001
LOG_LEVEL=info

# ── TLS (HTTPS) ───────────────────────────────────────────────────────────────
# Paths to PEM certificate and private key. Leave empty to use plain HTTP.
# The installer generates a self-signed cert at the paths below.
# To use your own cert, replace these paths or leave blank for plain HTTP.
SSL_CERT=C:\Program Files\dnshenet-server\server.crt
SSL_KEY=C:\Program Files\dnshenet-server\server.key

# ── Admin UI ─────────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Optional ─────────────────────────────────────────────────────────────────
# METRICS_PORT=9090
# PLAYWRIGHT_HEADLESS=true
# OPERATION_TIMEOUT_SEC=30
