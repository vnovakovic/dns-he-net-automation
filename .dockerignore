# SQLite databases — contain production credentials and account data, must never
# be baked into a Docker image even during local builds.
*.db
*.db-wal
*.db-shm

# Environment files — contain secrets (JWT_SECRET, ADMIN_PASSWORD, etc.)
.env
.env.*
!.env.example

# TLS private key — must never be included in an image
server.key
server.crt

# Build artifacts not needed in the image
dnshenet-server.exe
dnshenet-server.exe~
dnshenet-server-installer.exe
dnshenet-server-linux-amd64
dnshenet-server-windows-amd64.exe
screenshots.exe

# Development / planning files
.planning/
.git/
coverage.out
coverage.html
debug-*.html
